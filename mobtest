<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex">

<title>DnD Item Shop – DM</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&display=swap" rel="stylesheet">

<style>

*{
  box-sizing:border-box;
}

body{
  margin:0;
  min-height:100vh;
  background:#181818;
  color:white;
  font-family:Arial,sans-serif;
}

body *{
  transition:
    background 0.15s ease,
    color 0.15s ease,
    border-color 0.15s ease,
    transform 0.22s ease,
    box-shadow 0.22s ease,
    width 0.22s ease,
    max-width 0.22s ease,
    opacity 0.22s ease;
}

.container{
  display:grid;
  grid-template-columns:minmax(0,1fr) 340px;
  gap:20px;
  padding:20px;
  align-items:start;
}

.container.sidebar-collapsed{
  grid-template-columns:minmax(0,1fr) 0px;
}

.table-section{
  min-width:0;
  overflow-x:auto;
  -webkit-overflow-scrolling:touch;
}

.sidebar{
  background:#242424;
  border-radius:16px;
  padding:22px;
  position:sticky;
  top:20px;
  height:fit-content;
  border:1px solid #3a3a3a;
  box-shadow:0 0 24px rgba(0,0,0,0.4);

  width:340px;
  max-width:340px;

  overflow:hidden;
  opacity:1;
}

.sidebar *{
  transition:none !important;
}

.container.sidebar-collapsed .sidebar{
  width:0;
  max-width:0;
  padding-left:0;
  padding-right:0;
  border-width:0;
  opacity:0;
}

.sidebar h2,
h1{
  font-family:"Cinzel",serif;
}

.topbar{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  margin-bottom:14px;
}

.sheet-switcher{
  display:flex;
  gap:10px;
  margin-top:12px;
}

.sheet-btn{
  width:auto;
  padding:10px 18px;
  background:#333;
  border:1px solid #555;
  border-radius:10px;
  color:white;
  cursor:pointer;
  font-weight:bold;
}

.sheet-btn.active{
  background:#4f46e5;
  border-color:#7c74ff;
}

.toggle-sidebar{
  position:fixed;

  top:20px;
  right:20px;

  z-index:999;

  width:auto;
  padding:10px 14px;

  background:#333;
  border:1px solid #555;
  border-radius:10px;

  cursor:pointer;
  font-weight:bold;
  white-space:nowrap;

  box-shadow:
    0 4px 14px rgba(0,0,0,0.35);
}

.filter-group{
  margin-bottom:18px;
}

.filter-group label{
  display:block;
  margin-bottom:6px;
  font-weight:bold;
}

input,
button{
  width:100%;
  padding:11px;
  border-radius:10px;
  border:1px solid #444;
  font-size:15px;
  background:#1d1d1d;
  color:white;
}

.price-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}

button{
  background:#4f46e5;
  color:white;
  cursor:pointer;
  font-weight:bold;
}

button:hover{
  background:#665dff;
}

table{
  width:100%;
  min-width:850px;
  table-layout:fixed;
  border-collapse:collapse;
  background:#222;
  border-radius:14px;
  overflow:hidden;
}

th,
td{
  padding:12px;
  border-bottom:1px solid #3f3f3f;
  border-right:1px solid #353535;

  box-shadow:
    inset -1px 0 4px rgba(0,0,0,0.35),
    1px 0 2px rgba(255,255,255,0.03);

  text-align:left;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  position:relative;
}

th:last-child,
td:last-child{
  border-right:none;
}

th{
  background:#303030;
}

tbody tr:nth-child(even){
  background:#242424;
}

tbody tr:nth-child(odd){
  background:#2c2c2c;
}

tr:hover{
  background:#3a3a3a !important;
}

.sortable{
  cursor:pointer;
  user-select:none;
}

.sort-indicator{
  display:inline-block;
  margin-left:6px;
  font-size:11px;
  opacity:0.55;
  width:12px;
  text-align:center;
}

.price-gp{
  color:gold;
  font-weight:bold;
}

.price-sp{
  color:silver;
  font-weight:bold;
}

.price-cp{
  color:#c47a3a;
  font-weight:bold;
}

.item-link{
  color:#8ecbff;
  text-decoration:none;
  font-weight:bold;
}

.item-link:hover{
  text-decoration:underline;
}

.hover-full{
  position:absolute;
  left:10px;
  top:100%;
  z-index:50;

  background:#111;
  color:white;

  padding:8px 10px;
  border-radius:8px;

  border:1px solid #555;

  white-space:normal;
  max-width:500px;

  opacity:0;
  pointer-events:none;

  transform:translateY(4px);

  transition:
    opacity 0.12s ease,
    transform 0.12s ease !important;

  box-shadow:
    0 6px 18px rgba(0,0,0,0.45);
}

td:hover .hover-full{
  opacity:1;
  transform:translateY(0);
}

.rarity-common{
  color:#cfcfcf;
  font-weight:bold;
}

.rarity-uncommon{
  color:#57d657;
  font-weight:bold;
}

.rarity-rare{
  color:#5ea0ff;
  font-weight:bold;
}

.rarity-very-rare{
  color:#b46cff;
  font-weight:bold;
}

.rarity-legendary{
  color:#ff9b42;
  font-weight:bold;
}

.rarity-artifact{
  color:#ff4f4f;
  font-weight:bold;
}

.multi-select{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}

.multi-select button{
  width:auto;
  padding:8px 12px;
  background:#333;
  border:1px solid #555;
}

.multi-select button.active{
  background:#4f46e5;
  border-color:#7c74ff;
}

#buyableToggle{
  accent-color:#4f46e5;
}

.buyable-label{
  display:flex !important;
  align-items:center;
  gap:8px;
  cursor:pointer;
}

.buyable-label input{
  width:auto;
  margin:0;
}

@media (max-width:1100px){

  .container{
    grid-template-columns:1fr;
  }

  .sidebar{
    position:sticky;
    top:0;
    width:100%;
    max-width:100%;
    z-index:100;
  }

}

@media (max-width:700px){

  body{
    font-size:14px;
  }

  h1{
    font-size:24px;
    line-height:1.2;
  }

  th,
  td{
    padding:8px;
    font-size:13px;
  }

  .sheet-switcher{
    flex-wrap:wrap;
  }

  .sheet-btn{
    flex:1;
    text-align:center;
  }

  .sidebar{
    padding:16px;
  }

  .toggle-sidebar{
    top:10px;
    right:10px;
    padding:8px 10px;
    font-size:13px;
  }

  .multi-select{
    gap:6px;
  }

  .multi-select button{
    padding:6px 10px;
    font-size:12px;
  }

  .price-grid{
    grid-template-columns:1fr;
  }

}

</style>
</head>
<body>

<div class="container">

<div class="table-section">

<div class="topbar">

<h1>DnD Item Preisliste – DM</h1>

<div class="sheet-switcher">

<button
class="sheet-btn active"
data-sheet="magic"
>
Magic Items
</button>

<button
class="sheet-btn"
data-sheet="mundane"
>
Nonmagic Items
</button>

</div>

</div>

<table>

<thead>
<tr>

<th>Item</th>
<th>Type</th>
<th>Subtype</th>

<th id="rarityHeader">
Rarity
</th>

<th id="attuneHeader">
Attunement
</th>

<th>Preis</th>
<th>Anmerkung</th>
<th>Tier</th>

</tr>
</thead>

<tbody id="tableBody"></tbody>

</table>

</div>

<div class="sidebar">

<h2>Suchfilter</h2>

<div class="filter-group">
<label>Type</label>
<div id="typeFilter" class="multi-select"></div>
</div>

<div class="filter-group" id="rarityGroup">
<label>Rarity</label>
<div id="rarityFilter" class="multi-select"></div>
</div>

<div class="filter-group" id="attuneGroup">

<label>Attunement</label>

<div id="attuneButtons" class="multi-select">

<button
type="button"
class="attune-btn active"
data-value="Alle"
>
Alle
</button>

<button
type="button"
class="attune-btn"
data-value="Ja"
>
Ja
</button>

<button
type="button"
class="attune-btn"
data-value="Nein"
>
Nein
</button>

</div>

</div>

<div class="filter-group">
<label>Preis</label>

<div class="price-grid">
<input type="number" id="priceMin" placeholder="von">
<input type="number" id="priceMax" placeholder="bis">
</div>
</div>

<div class="filter-group">
<label>Suchbegriff</label>
<input type="text" id="searchInput">
</div>

<div>
Suchergebnisse:
<span id="resultCount">0</span>
</div>

</div>

</div>

<script>

const SHEETS = {

  magic:{
    id:"1yWXMERywTtgi-fKcmfTYgkSZ3abmnM0pNnZgYTfjToY",
    name:"Magic Items"
  },

  mundane:{
    id:"154iNJR9P_rwltW24M3hXyge33G_ym3cdMQVmPwQe4Bk",
    name:"Nonmagic Items"
  }

};

let currentSheet = "magic";

let items = [];

let selectedTypes = [];
let selectedRarities = [];

let attuneState = "Alle";

function isMundaneSheet(){
  return currentSheet === "mundane";
}

function formatPrice(price){

  if(price >= 1){

    return {
      text:`${price} GP`,
      className:"price-gp"
    };

  }

  if(price >= 0.1){

    return {
      text:`${Math.round(price * 10)} SP`,
      className:"price-sp"
    };

  }

  return {
    text:`${Math.round(price * 100)} CP`,
    className:"price-cp"
  };

}

function updateFilterVisibility(){

  document.getElementById("rarityGroup")
    .style.display =
      isMundaneSheet()
        ? "none"
        : "block";

  document.getElementById("attuneGroup")
    .style.display =
      isMundaneSheet()
        ? "none"
        : "block";

  document.getElementById("rarityHeader")
    .style.display =
      isMundaneSheet()
        ? "none"
        : "";

  document.getElementById("attuneHeader")
    .style.display =
      isMundaneSheet()
        ? "none"
        : "";

}

async function loadSheet(){

  const config =
    SHEETS[currentSheet];

  const url =
    `https://docs.google.com/spreadsheets/d/${config.id}/gviz/tq?sheet=${encodeURIComponent(config.name)}`;

  const response =
    await fetch(url);

  const text =
    await response.text();

  const json =
    JSON.parse(
      text.substring(47).slice(0,-2)
    );

  const rows =
    json.table.rows;

  items = rows.map(row => {

    const cells = row.c || [];

    return {

      name:cells[0]?.v ?? "",
      link:cells[1]?.v ?? "",
      type:cells[2]?.v ?? "",
      subtype:cells[3]?.v ?? "",
      rarity:cells[4]?.v ?? "",
      attunement:cells[5]?.v ?? "",
      price:Number(cells[6]?.v ?? 0),
      extra:cells[7]?.v ?? "",
      tier:cells[8]?.v ?? ""

    };

  });

  buildFilters();
  updateFilterVisibility();
  filterItems();

}

function buildFilters(){

  buildMultiSelect(
    "typeFilter",
    [...new Set(items.map(i => i.type))],
    selectedTypes
  );

  buildMultiSelect(
    "rarityFilter",
    [...new Set(items.map(i => i.rarity))]
      .filter(Boolean),
    selectedRarities
  );

}

function buildMultiSelect(
  id,
  values,
  selectedArray
){

  const container =
    document.getElementById(id);

  container.innerHTML = "";

  values.sort();

  values.forEach(value => {

    const button =
      document.createElement("button");

    button.textContent = value;

    if(selectedArray.includes(value)){
      button.classList.add("active");
    }

    button.addEventListener("click",()=>{

      if(selectedArray.includes(value)){

        selectedArray.splice(
          selectedArray.indexOf(value),
          1
        );

      }else{

        selectedArray.push(value);

      }

      buildFilters();
      filterItems();

    });

    container.appendChild(button);

  });

}

function filterItems(){

  const search =
    document.getElementById("searchInput")
      .value
      .toLowerCase();

  const priceMin =
    Number(
      document.getElementById("priceMin").value || 0
    );

  const priceMax =
    Number(
      document.getElementById("priceMax").value || Infinity
    );

  let filtered = items.filter(item => {

    if(!item.price || item.price <= 0)
      return false;

    if(
      selectedTypes.length &&
      !selectedTypes.includes(item.type)
    )
      return false;

    if(
      !isMundaneSheet() &&
      selectedRarities.length &&
      !selectedRarities.includes(item.rarity)
    )
      return false;

    if(!isMundaneSheet()){

      if(
        attuneState === "Ja" &&
        item.attunement === ""
      )
        return false;

      if(
        attuneState === "Nein" &&
        item.attunement !== ""
      )
        return false;

    }

    if(item.price < priceMin)
      return false;

    if(item.price > priceMax)
      return false;

    const combined =
      `${item.name} ${item.subtype}`
        .toLowerCase();

    if(
      search &&
      !combined.includes(search)
    )
      return false;

    return true;

  });

  renderTable(filtered);

  document.getElementById("resultCount")
    .textContent = filtered.length;

}

function renderTable(data){

  const body =
    document.getElementById("tableBody");

  body.innerHTML = "";

  data.forEach(item => {

    const tr =
      document.createElement("tr");

    const rarityClass =
      String(item.rarity)
        .toLowerCase()
        .replace(/\s+/g,"-");

    const priceData =
      formatPrice(item.price);

    tr.innerHTML = `

      <td>
        <a
        class="item-link"
        href="${item.link}"
        target="_blank"
        >
          ${item.name}
        </a>
      </td>

      <td>${item.type}</td>

      <td>${item.subtype}</td>

      ${
        isMundaneSheet()
        ? ""
        : `
          <td class="rarity-${rarityClass}">
            ${item.rarity}
          </td>

          <td>
            ${item.attunement || "-"}
          </td>
        `
      }

      <td class="${priceData.className}">
        ${priceData.text}
      </td>

      <td>${item.extra}</td>

      <td>${item.tier}</td>

    `;

    body.appendChild(tr);

  });

}

document
  .querySelectorAll(".sheet-btn")
  .forEach(button => {

    button.addEventListener("click",()=>{

      document
        .querySelectorAll(".sheet-btn")
        .forEach(btn =>
          btn.classList.remove("active")
        );

      button.classList.add("active");

      currentSheet =
        button.dataset.sheet;

      selectedTypes = [];
      selectedRarities = [];

      loadSheet();

    });

  });

document
  .querySelectorAll(".attune-btn")
  .forEach(button => {

    button.addEventListener("click",()=>{

      document
        .querySelectorAll(".attune-btn")
        .forEach(btn =>
          btn.classList.remove("active")
        );

      button.classList.add("active");

      attuneState =
        button.dataset.value;

      filterItems();

    });

  });

document
  .getElementById("searchInput")
  .addEventListener("input",filterItems);

document
  .getElementById("priceMin")
  .addEventListener("input",filterItems);

document
  .getElementById("priceMax")
  .addEventListener("input",filterItems);

loadSheet();

</script>

</body>
</html>
